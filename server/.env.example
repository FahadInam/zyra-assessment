# Copy this file to .env and fill in the value below.
#
# Option A — local MongoDB via Docker (no account needed):
#   1. Run: docker compose up -d  (from the repo root)
#   2. Use this connection string:
MONGODB_URI=mongodb://localhost:27017/action-center
#
# Option B — free MongoDB Atlas cluster:
#   1. Sign up at https://www.mongodb.com/cloud/atlas (free tier)
#   2. Create a cluster, get the connection string, and paste it here:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/action-center?appName=Cluster0

PORT=4000
